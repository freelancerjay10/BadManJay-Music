body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #111;
  color: white;
}

header {
  text-align: center;
  padding: 60px 20px;
  background: #222;
}

h1 {
  font-size: 48px;
}

p {
  font-size: 18px;
}

section {
  padding: 40px 20px;
  text-align: center;
}

button {
  background: #e67e22;
  color: white;
  padding: 12px 25px;
  border: none;
  border-radius: 5px;
}
